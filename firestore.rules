rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // USER PROFILE COLLEXTION
    match /users/{userId} {
      allow read, write: if true;
    }

    // INVOICES & ORDERS
    match /orders/{orderId} {
      allow read, write: if true;
    }
  }
}
