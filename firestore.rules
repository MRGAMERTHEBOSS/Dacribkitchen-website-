rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global default deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Authentication validations
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSystemOwner() {
      return isSignedIn() && request.auth.token.email.lower() == 'owner@dacrib.com';
    }

    // Static data valid size/regex boundaries
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User model schema integrity check
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
        && data.keys().size() == 4
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    // Order model schema integrity check
    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'userId', 'customerName', 'items', 'subtotal', 'deliveryFee', 'grandTotal', 'orderType', 'status', 'createdAt'])
        && data.orderId is string && data.orderId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.customerName is string && data.customerName.size() <= 128
        && data.items is list && data.items.size() <= 100
        && data.subtotal is number && data.subtotal >= 0
        && data.deliveryFee is number && data.deliveryFee >= 0
        && data.grandTotal is number && data.grandTotal >= 0
        && data.orderType is string && (data.orderType == 'pickup' || data.orderType == 'delivery')
        && data.status is string && (data.status == 'pending' || data.status == 'confirmed' || data.status == 'cooking' || data.status == 'ready' || data.status == 'out_for_delivery' || data.status == 'completed' || data.status == 'cancelled')
        && data.createdAt is string && data.createdAt.size() <= 128;
    }

    // RESTRICTED COLLECTION: USERS
    match /users/{userId} {
      allow read: if isOwner(userId) || isSystemOwner();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }

    // RESTRICTED COLLECTION: INVOICES & ORDERS
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isSystemOwner());
      // Secure list query: client MUST include "where('userId', '==', uid)" filter unless system owner
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isSystemOwner());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isSystemOwner() && isValidOrder(request.resource.data);
      allow delete: if false;
    }
  }
}
